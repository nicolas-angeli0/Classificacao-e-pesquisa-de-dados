import os
import time
import timeit
import random
import sys

sys.setrecursionlimit(30000)

def numeros_aleatorios(inicio, final, quantidade):
    random.seed(2026)
    numeros = []
    for _ in range(quantidade):
        numeros.append(random.randint(inicio, final))
    return numeros

def bubble_sort(array):
    tamanho = len(array)
    for i in range(tamanho):
        for j in range(0, tamanho - i - 1):
            if array[j] > array[j + 1]:
                array[j], array[j + 1] = array[j + 1], array[j]
    return array

def bubble_sort_otimizado(array):
    tamanho = len(array)
    for i in range(tamanho):
        trocou = False
        for j in range(0, tamanho - i - 1):
            if array[j] > array[j + 1]:
                array[j], array[j + 1] = array[j + 1], array[j]
                trocou = True
        if not trocou:
            break
    return array

def selection_sort(array):
    tamanho = len(array)
    for i in range(tamanho - 1):
        menor = i
        for j in range(i + 1, tamanho):
            if array[j] < array[menor]:
                menor = j
        array[i], array[menor] = array[menor], array[i]
    return array

def selection_sort_recursivo(array, inicio=0):
    tamanho = len(array)
    if inicio >= tamanho - 1:
        return array
    menor = inicio
    for j in range(inicio + 1, tamanho):
        if array[j] < array[menor]:
            menor = j
    array[inicio], array[menor] = array[menor], array[inicio]
    return selection_sort_recursivo(array, inicio + 1)

def insertion_sort(array):
    tamanho = len(array)
    for i in range(1, tamanho):
        chave = array[i]
        j = i - 1
        while j >= 0 and array[j] > chave:
            array[j + 1] = array[j]
            j -= 1
        array[j + 1] = chave
    return array

def insertion_sort_binario(array):
    tamanho = len(array)
    for i in range(1, tamanho):
        chave = array[i]
        esq, dir = 0, i - 1
        while esq <= dir:
            meio = (esq + dir) // 2
            if array[meio] < chave:
                esq = meio + 1
            else:
                dir = meio - 1
        for j in range(i - 1, esq - 1, -1):
            array[j + 1] = array[j]
        array[esq] = chave
    return array

def shell_sort(array):
    tamanho = len(array)
    gap = tamanho // 2
    while gap > 0:
        for i in range(gap, tamanho):
            chave = array[i]
            j = i
            while j >= gap and array[j - gap] > chave:
                array[j] = array[j - gap]
                j -= gap
            array[j] = chave
        gap //= 2
    return array

def shell_sort_knuth(array):
    tamanho = len(array)
    gap = 1
    while gap < tamanho // 3:
        gap = 3 * gap + 1
    while gap > 0:
        for i in range(gap, tamanho):
            chave = array[i]
            j = i
            while j >= gap and array[j - gap] > chave:
                array[j] = array[j - gap]
                j -= gap
            array[j] = chave
        gap //= 3
    return array

def merge_sort(array):
    if len(array) > 1:
        tamanho = len(array)
        meio = tamanho // 2
        esquerda = array[:meio]
        direita = array[meio:]
        
        merge_sort(esquerda)
        merge_sort(direita)

        i = j = k = 0
        
        while i < len(esquerda) and j < len(direita):
            if esquerda[i] <= direita[j]:
                array[k] = esquerda[i]
                i = i + 1
            else:
                array[k] = direita[j]
                j = j + 1
            k = k + 1
            
        while i < len(esquerda):
            array[k] = esquerda[i]
            i = i + 1
            k = k + 1
            
        while j < len(direita):
            array[k] = direita[j]
            j = j + 1
            k = k + 1
            
    return array

def merge_sort_otimizado(array):
    if len(array) <= 15:
        return insertion_sort(array)

    tamanho = len(array)
    meio = tamanho // 2
    esquerda=array[: meio]
    direita=array[meio :]

    merge_sort_otimizado(esquerda)
    merge_sort_otimizado(direita)

    i= j= k=0
    while i < len(esquerda) and j < len(direita):
            if esquerda[i] <= direita[j]:
                array[k] = esquerda[i]
                i = i + 1
            else:
                array[k] = direita[j]
                j = j + 1
            k = k + 1

    while i < len(esquerda):
            array[k] = esquerda[i]
            i = i + 1
            k = k + 1
            
    while j < len(direita):
        array[k] = direita[j]
        j = j + 1
        k = k + 1
            
    return array

def heap_sort(array):
    def heapify(array, n, i):
        maior=i
        esquerda=2*i+1
        direita=2*i+2       
        
        if esquerda < n and array[esquerda] > array[maior]:
            maior=esquerda
        if direita < n and array[direita] > array[maior]:
            maior=direita
        if maior!=i:
            array[i], array[maior] = array[maior], array[i]
            heapify(array, n, maior)

    tamanho=len(array)
    
    for i in range(tamanho // 2 - 1, -1, -1):
        heapify(array, tamanho, i)

    for i in range(tamanho - 1, 0, -1):
        array[i], array[0] = array[0], array[i]
        heapify(array, i, 0)

    return array

def heap_sort_otimizado(array):
    def heapify(array, n, i):
        while True:
            maior = i
            esquerda = 2 * i + 1
            direita = 2 * i + 2       
            
            if esquerda < n and array[esquerda] > array[maior]:
                maior = esquerda
            if direita < n and array[direita] > array[maior]:
                maior = direita
            
            if maior == i:
                break
                
            array[i], array[maior] = array[maior], array[i]
            i = maior

    tamanho = len(array)
    
    for i in range(tamanho // 2 - 1, -1, -1):
        heapify(array, tamanho, i)

    for i in range(tamanho - 1, 0, -1):
        array[i], array[0] = array[0], array[i]
        heapify(array, i, 0)

    return array

def quick_sort(array):
    def partition(array, inicio, fim):
        pivo = array[fim]
        i = inicio - 1
        
        for j in range(inicio, fim):
            if array[j] <= pivo:
                i = i + 1
                array[i], array[j] = array[j], array[i]
        
        array[i + 1], array[fim] = array[fim], array[i + 1]
        return i + 1

    def sort(array, inicio, fim):
        if inicio < fim:
            pi = partition(array, inicio, fim)
            sort(array, inicio, pi - 1)
            sort(array, pi + 1, fim)

    sort(array, 0, len(array) - 1)
    return array

def quick_sort_otimizado(array):
    def divisao(array, inicio, fim):
        pivo = array[fim]
        i = inicio - 1
        
        for j in range(inicio, fim):
            if array[j] <= pivo:
                i = i + 1
                array[i], array[j] = array[j], array[i]
        
        array[i + 1], array[fim] = array[fim], array[i + 1]
        return i + 1

    def sort(array, inicio, fim):
        if inicio < fim:
            tamanho = fim - inicio + 1
            
            if tamanho <= 15:
                for k in range(inicio + 1, fim + 1):
                    chave = array[k]
                    j = k - 1
                    while j >= inicio and array[j] > chave:
                        array[j + 1] = array[j]
                        j = j - 1
                    array[j + 1] = chave
            else:
                pi = divisao(array, inicio, fim)
                sort(array, inicio, pi - 1)
                sort(array, pi + 1, fim)

    sort(array, 0, len(array) - 1)
    return array

def counting_sort(array):
    if len(array) == 0:
        return array
        
    maior = max(array)
    tamanho = len(array)
    saida = [0] * tamanho
    contagem = [0] * (maior + 1)

    for i in range(tamanho):
        contagem[array[i]] += 1

    for i in range(1, maior + 1):
        contagem[i] += contagem[i - 1]

    i = tamanho - 1
    while i >= 0:
        saida[contagem[array[i]] - 1] = array[i]
        contagem[array[i]] -= 1
        i -= 1

    for i in range(tamanho):
        array[i] = saida[i]
        
    return array

def radix_sort(array):
    def counting_sort_radix(array, exp):
        tamanho = len(array)
        saida = [0] * tamanho
        contagem = [0] * 10

        for i in range(tamanho):
            indice = array[i] // exp
            contagem[indice % 10] += 1

        for i in range(1, 10):
            contagem[i] += contagem[i - 1]

        i = tamanho - 1
        while i >= 0:
            indice = array[i] // exp
            saida[contagem[indice % 10] - 1] = array[i]
            contagem[indice % 10] -= 1
            i -= 1

        for i in range(tamanho):
            array[i] = saida[i]

    if len(array) == 0:
        return array
        
    maior = max(array)
    exp = 1
    while maior // exp > 0:
        counting_sort_radix(array, exp)
        exp = exp * 10
        
    return array

def bucket_sort(array):
    if len(array) == 0:
        return array
    
    maior = max(array)
    tamanho = len(array)
    baldes = []
    
    for _ in range(tamanho):
        baldes.append([])
        
    for num in array:
        indice_balde = (num * tamanho) // (maior + 1)
        baldes[indice_balde].append(num)
        
    for balde in baldes:
        insertion_sort(balde)
        
    k = 0
    for balde in baldes:
        for num in balde:
            array[k] = num
            k = k + 1
            
    return array

def medir_tempo(metodo, lista_original, repeticoes=3):
    tempo = timeit.timeit(
        stmt=lambda: metodo(lista_original.copy()),
        number=repeticoes
    ) / repeticoes
    return tempo

def formatar_resultado(tempo, tempo_pior):
    if tempo == tempo_pior:
        return str(round(tempo, 4)) + "s (Ref)"
    dif_relativa = ((tempo_pior - tempo) / tempo_pior) * 100
    return str(round(tempo, 4)) + "s (+" + str(round(dif_relativa, 1)) + "%)"

def main():
    if os.name == 'nt':
        os.system('cls')
    else:
        os.system('clear')
        
    print("Trabalho de Estrutura de Dados - Ordenação de Algoritmos")
    time.sleep(1.5)
    print(" > Iniciando motor de testes...")
    time.sleep(1)
    
    start_time = time.time()
    tamanho = 2500
    
    print(" > Gerando vetores (Aleatório, Crescente e Decrescente)...")
    numeros_aleatorios_lista = numeros_aleatorios(0, 10000, tamanho)
    numeros_ordenados = sorted(numeros_aleatorios_lista)
    numeros_inversos = sorted(numeros_aleatorios_lista, reverse=True)
    
    algoritmos = {
        "Bubble Sort": bubble_sort,
        "Bubble Otimizado": bubble_sort_otimizado,
        "Selection Sort": selection_sort,
        "Selection Recursivo": selection_sort_recursivo,
        "Insertion Sort": insertion_sort,
        "Insertion Binário": insertion_sort_binario,
        "Shell Sort": shell_sort,
        "Shell Knuth": shell_sort_knuth,
        "Merge Sort": merge_sort,
        "Merge Sort Otimizado": merge_sort_otimizado,
        "Heap Sort": heap_sort,
        "Heap Sort Otimizado": heap_sort_otimizado,
        "Quick Sort": quick_sort,
        "Quick Sort Otimizado": quick_sort_otimizado,
        "Counting Sort": counting_sort,
        "Radix Sort": radix_sort,
        "Bucket Sort": bucket_sort,
    }

    print()
    print("[!] Entradas geradas com n =", tamanho, ". Calculando valores, por favor aguarde...")
    print()
    print("-" * 88)

    for nome, algoritmo in algoritmos.items():
        t_aleatorio = medir_tempo(algoritmo, numeros_aleatorios_lista)
        t_ordenado = medir_tempo(algoritmo, numeros_ordenados)
        t_inverso = medir_tempo(algoritmo, numeros_inversos)

        pior = max(t_aleatorio, t_ordenado, t_inverso)

        r_aleatorio = formatar_resultado(t_aleatorio, pior)
        r_ordenado = formatar_resultado(t_ordenado, pior)
        r_inverso = formatar_resultado(t_inverso, pior)

        print("Método:", nome)
        print("Aleatória:", r_aleatorio, "| Ordenada:", r_ordenado, "| Inversa (Pior):", r_inverso)
        print("-" * 88)

    end_time = time.time()
    print()
    print("Processo finalizado com sucesso em", round(end_time - start_time, 2), "segundos.")

if __name__ == "__main__":
    main()

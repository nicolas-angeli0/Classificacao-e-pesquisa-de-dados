import os
import time
import timeit
import random
import sys

sys.setrecursionlimit(30000)

def numeros_aleatorios(inicio, final, quantidade):
    random.seed(2026)
    numeros = []
    for _ in range(quantidade):
        numeros.append(random.randint(inicio, final))
    return numeros

def bubble_sort(array):
    tamanho = len(array)
    for i in range(tamanho):
        for j in range(0, tamanho - i - 1):
            if array[j] > array[j + 1]:
                array[j], array[j + 1] = array[j + 1], array[j]
    return array

def bubble_sort_otimizado(array):
    tamanho = len(array)
    for i in range(tamanho):
        trocou = False
        for j in range(0, tamanho - i - 1):
            if array[j] > array[j + 1]:
                array[j], array[j + 1] = array[j + 1], array[j]
                trocou = True
        if not trocou:
            break
    return array

def selection_sort(array):
    tamanho = len(array)
    for i in range(tamanho - 1):
        menor = i
        for j in range(i + 1, tamanho):
            if array[j] < array[menor]:
                menor = j
        array[i], array[menor] = array[menor], array[i]
    return array

def selection_sort_recursivo(array, inicio=0):
    tamanho = len(array)
    if inicio >= tamanho - 1:
        return array
    menor = inicio
    for j in range(inicio + 1, tamanho):
        if array[j] < array[menor]:
            menor = j
    array[inicio], array[menor] = array[menor], array[inicio]
    return selection_sort_recursivo(array, inicio + 1)

def insertion_sort(array):
    tamanho = len(array)
    for i in range(1, tamanho):
        chave = array[i]
        j = i - 1
        while j >= 0 and array[j] > chave:
            array[j + 1] = array[j]
            j -= 1
        array[j + 1] = chave
    return array

def insertion_sort_binario(array):
    tamanho = len(array)
    for i in range(1, tamanho):
        chave = array[i]
        esq, dir = 0, i - 1
        while esq <= dir:
            meio = (esq + dir) // 2
            if array[meio] < chave:
                esq = meio + 1
            else:
                dir = meio - 1
        for j in range(i - 1, esq - 1, -1):
            array[j + 1] = array[j]
        array[esq] = chave
    return array

def shell_sort(array):
    tamanho = len(array)
    gap = tamanho // 2
    while gap > 0:
        for i in range(gap, tamanho):
            chave = array[i]
            j = i
            while j >= gap and array[j - gap] > chave:
                array[j] = array[j - gap]
                j -= gap
            array[j] = chave
        gap //= 2
    return array

def shell_sort_knuth(array):
    tamanho = len(array)
    gap = 1
    while gap < tamanho // 3:
        gap = 3 * gap + 1
    while gap > 0:
        for i in range(gap, tamanho):
            chave = array[i]
            j = i
            while j >= gap and array[j - gap] > chave:
                array[j] = array[j - gap]
                j -= gap
            array[j] = chave
        gap //= 3
    return array

def medir_tempo(metodo, lista_original, repeticoes=3):
    tempo = timeit.timeit(
        stmt=lambda: metodo(lista_original.copy()),
        number=repeticoes
    ) / repeticoes
    return tempo

def formatar_resultado(tempo, tempo_pior):
    if tempo == tempo_pior:
        return f"{tempo:.4f}s (Ref)"
    dif_relativa = ((tempo_pior - tempo) / tempo_pior) * 100
    return f"{tempo:.4f}s (+{dif_relativa:.1f}%)"

def main():
    if os.name == 'nt':
        os.system('cls')
    else:
        os.system('clear')
        
    print("Trabalho de Estrutura de Dados - Ordenação de Algoritmos")
    time.sleep(1.5)
    print(" > Iniciando motor de testes...")
    time.sleep(1)
    
    start_time = time.time()
    tamanho = 2500
    
    print(" > Gerando vetores (Aleatório, Crescente e Decrescente)...")
    numeros_aleatorios_lista = numeros_aleatorios(0, 10000, tamanho)
    numeros_ordenados = sorted(numeros_aleatorios_lista)
    numeros_inversos = sorted(numeros_aleatorios_lista, reverse=True)
    
    algoritmos = {
        "Bubble Sort": bubble_sort,
        "Bubble Otimizado": bubble_sort_otimizado,
        "Selection Sort": selection_sort,
        "Selection Recursivo": selection_sort_recursivo,
        "Insertion Sort": insertion_sort,
        "Insertion Binário": insertion_sort_binario,
        "Shell Sort": shell_sort,
        "Shell Knuth": shell_sort_knuth
    }

    print(f"\n[!] Entradas geradas com n = {tamanho}. Calculando valores, por favor aguarde...\n")
    print("-" * 88)
    print(f"| {'Método':<20} | {'Aleatória':<18} | {'Ordenada':<18} | {'Inversa (Pior)':<18} |")
    print("-" * 88)

    for nome, algoritmo in algoritmos.items():
        t_aleatorio = medir_tempo(algoritmo, numeros_aleatorios_lista)
        t_ordenado = medir_tempo(algoritmo, numeros_ordenados)
        t_inverso = medir_tempo(algoritmo, numeros_inversos)

        pior = max(t_aleatorio, t_ordenado, t_inverso)

        r_aleatorio = formatar_resultado(t_aleatorio, pior)
        r_ordenado = formatar_resultado(t_ordenado, pior)
        r_inverso = formatar_resultado(t_inverso, pior)

        print(f"| {nome:<20} | {r_aleatorio:<18} | {r_ordenado:<18} | {r_inverso:<18} |")

    print("-" * 88)
    end_time = time.time()
    print(f"\n<✓> Processo finalizado com sucesso em {end_time - start_time:.2f} segundos.")

if __name__ == "__main__":
    main()

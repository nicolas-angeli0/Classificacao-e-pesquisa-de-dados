    ])

    trie.inserir_palavra("casa")
    trie.inserir_palavra("casa")
    trie.inserir_palavra("casa")

    trie.inserir_palavra("carro")
    trie.inserir_palavra("carro")

    print("Sugestões para 'ca':")
    print(trie.sugerir_palavra("ca",5))

    print()

    print("Removendo 'casaco'")
    trie.remover_palavra("casaco")

    print()

    print("Sugestões após remoção:")
    print(trie.sugerir_palavra("ca",10))

    print()

    print("Corretor para 'cassa':")
    print(trie.corrigir_palavra("cassa"))

    print()

    print("Corretor para 'carroo':")
    print(trie.corrigir_palavra("carroo"))
